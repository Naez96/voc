# Configuration du serveur
PORT=3002
NODE_ENV=production
DOMAIN=voc.naez.fr

# Certificats SSL (Let's Encrypt)
SSL_CERT_PATH=/etc/letsencrypt/live/voc.naez.fr/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/voc.naez.fr/privkey.pem

# Logs
LOG_LEVEL=info

# Optionnel: Configuration PM2
PM2_APP_NAME=chat-vocal-voc-naez
PM2_INSTANCES=1